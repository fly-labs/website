# ===========================================
# FlyLabs Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# -------------------------------------------
# Client-side (Vite, exposed to the browser)
# -------------------------------------------

# Supabase project URL (e.g. https://your-project.supabase.co)
VITE_SUPABASE_URL=

# Supabase anon/public key (safe for client-side use)
VITE_SUPABASE_ANON_KEY=

# Google Analytics 4 Measurement ID (optional, e.g. G-XXXXXXXXXX)
VITE_GA_ID=

# -------------------------------------------
# Server-side (scripts, GitHub Actions)
# -------------------------------------------

# Supabase project URL (scripts read both SUPABASE_URL and VITE_SUPABASE_URL)
SUPABASE_URL=

# Supabase service role key (full access, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic API key for Claude scoring + sync filters
ANTHROPIC_API_KEY=

# Product Hunt API credentials (for sync-producthunt.mjs)
PRODUCTHUNT_API_KEY=
PRODUCTHUNT_API_SECRET=

# xAI API key for Grok x_search (for sync-x.mjs + enrich-ideas.mjs)
XAI_API_KEY=

# Reddit OAuth credentials (optional, enables higher rate limits for sync-reddit.mjs)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# GitHub personal access token (optional, 5K req/hr vs 60 for sync-github.mjs)
GITHUB_TOKEN=

# -------------------------------------------
# Cloudflare R2 (music storage, zero egress)
# -------------------------------------------

# Cloudflare account ID (from dashboard URL: dash.cloudflare.com/ACCOUNT_ID)
R2_ACCOUNT_ID=

# R2 API token credentials (create at R2 > Manage API Tokens)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# R2 bucket name (default: flylabs-music)
R2_BUCKET_NAME=flylabs-music

# R2 public URL (from bucket settings > Public access, e.g. https://pub-xxx.r2.dev)
R2_PUBLIC_URL=
