# Supabase - Get these from your Supabase project: Settings > API
# Format: https://your-project-id.supabase.co
VITE_SUPABASE_URL=https://your-project.supabase.co
# Format: eyJhbGciOiJIUzI1NiIs... (long JWT string)
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google Analytics 4 (optional) - Leave empty to disable tracking
# Format: G-XXXXXXXXXX
VITE_GA_ID=

# ── Server-side (scripts only, not needed for frontend) ──

# Supabase service role key (for sync/score/enrich scripts)
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic API key (for scoring with Claude)
ANTHROPIC_API_KEY=

# Product Hunt API (for sync:producthunt)
PRODUCTHUNT_API_KEY=
PRODUCTHUNT_API_SECRET=

# xAI / Grok API (for sync:x and enrichment)
XAI_API_KEY=

# Reddit OAuth (optional - enables higher rate limits for sync:reddit and enrichment)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# GitHub personal access token (optional - 5K req/hr vs 60 for sync:github)
GITHUB_TOKEN=
