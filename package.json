{
  "name": "flylabs-website",
  "version": "1.0.0",
  "description": "The Fly Labs website. Tools, templates, and AI prompts built in public.",
  "private": true,
  "license": "MIT",
  "author": "Fly Labs <talktoflyflabs@gmail.com> (https://flylabs.fun)",
  "repository": {
    "type": "git",
    "url": "https://github.com/fly-labs/website.git"
  },
  "homepage": "https://flylabs.fun",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "npm run dev --prefix apps/web",
    "build": "npm run build --prefix apps/web",
    "preview": "npm run start --prefix apps/web",
    "lint": "npm run lint --prefix apps/web",
    "deploy": "git push origin main",
    "sync": "node scripts/sync-problemhunt.mjs",
    "sync:reddit": "node scripts/sync-reddit.mjs",
    "sync:producthunt": "node scripts/sync-producthunt.mjs",
    "sync:x": "node scripts/sync-x.mjs",
    "sync:hackernews": "node scripts/sync-hackernews.mjs",
    "sync:github": "node scripts/sync-github.mjs",
    "sync:yc": "node scripts/sync-yc.mjs",
    "score": "node scripts/score-ideas.mjs",
    "score:backfill": "node scripts/score-ideas.mjs --all --backfill",
    "score:yc": "node scripts/backfill-yc.mjs",
    "enrich": "node scripts/enrich-ideas.mjs",
    "setup:music": "node --env-file=apps/web/.env scripts/setup-music.mjs",
    "translate": "node scripts/translate-missing.mjs",
    "translate:auto": "node scripts/translate-missing.mjs --translate"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@aws-sdk/client-s3": "^3.1009.0",
    "@supabase/supabase-js": "^2.49.1",
    "dotenv": "^17.3.1"
  },
  "workspaces": [
    "apps/*"
  ],
  "overrides": {
    "dompurify": "3.3.3",
    "mermaid": "10.9.5",
    "@excalidraw/excalidraw": {
      "nanoid": "3.3.11"
    },
    "@excalidraw/mermaid-to-excalidraw": {
      "nanoid": "5.1.3"
    }
  },
  "dependencies": {
    "@vercel/og": "^0.11.1",
    "i18next": "^25.8.18",
    "i18next-browser-languagedetector": "^8.2.1",
    "react-i18next": "^16.5.8",
    "web-vitals": "^5.1.0"
  }
}
